PORT=5000

# Base de datos MySQL
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=pos_online_db

# Seguridad
JWT_SECRET=super_secreta_pos_online_token_key_987654321

# Configuración de Correo SMTP (Opcional)
# Si se dejan vacíos, el sistema creará una cuenta de prueba gratuita en Ethereal Mail
# y mostrará el enlace de la factura recibida en la consola del servidor.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@sistema-pos-online.local
